# 服务端口（默认 3000）
PORT=3000
# 运行环境: development | production
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=wife_order

# 会话密钥（必填，服务启动必须提供）
SESSION_SECRET=your_session_secret_here

# 互亿无线短信配置
# SMS_API_URL 可自定义短信服务地址（默认 106.ihiyi.com）
SMS_API_URL=http://106.ihiyi.com/webservice/sms.php
# APIID（请替换为你的实际值）
SMS_API_ID=your_api_id_here
# APIKEY（请替换为你的实际值）
SMS_API_KEY=your_api_key_here
# 短信签名内容（自定义审核通过后替换，免费期使用"互亿无线"）
SMS_SIGN_NAME=互亿无线
# 短信模板ID（自定义审核通过后替换为 325815，免费期使用"1"）
SMS_TEMPLATE_ID=1

# 网站正式上线日期 (用于计算运营时长)
SITE_LAUNCH_DATE=2026-05-15T00:00:00

# 测试模式：跳过短信发送 (dev=true, prod=false 或删除)
TEST_SKIP_SMS=false

# 超级管理员后台登录凭据
DASHBOARD_USER=admin
DASHBOARD_PASS=your_strong_password_here
