<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>家庭私厨 · 管理后台</title>
  <link rel="stylesheet" href="/dashboard.css?v=2">
</head>
<body class="dashboard-page">

<% if (!loggedIn) { %>
  <!-- 登录页 -->
  <div class="dash-login-wrap">
    <div class="dash-login-card">
      <h1 class="dash-login-title">家庭私厨 · 管理后台</h1>
      <form method="POST" action="/dashboard/login">
        <input class="dash-login-input" type="text" name="username" placeholder="管理员账号" autofocus required>
        <input class="dash-login-input" type="password" name="password" placeholder="管理员密码" required>
        <% if (locals.error) { %><p class="dash-login-error"><%= error %></p><% } %>
        <button class="dash-login-btn" type="submit">登录</button>
      </form>
    </div>
  </div>

<% } else { %>

  <!-- 管理后台布局 -->
  <div class="dashboard-layout">

    <!-- 移动端遮罩 -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <!-- 左侧导航栏 -->
    <aside class="dashboard-sidebar" id="sidebar">
      <div class="sidebar-brand">
        <div class="sidebar-brand-name">家庭私厨 · 管理后台</div>
      </div>
      <nav class="sidebar-nav">
        <a class="sidebar-nav-item active" data-tab="overview" onclick="switchTab('overview')">
          <span class="nav-icon">📊</span> 数据概览
        </a>
        <a class="sidebar-nav-item" data-tab="users" onclick="switchTab('users')">
          <span class="nav-icon">👥</span> 用户管理
        </a>
        <a class="sidebar-nav-item" data-tab="families" onclick="switchTab('families')">
          <span class="nav-icon">🏠</span> 家庭组管理
        </a>
        <a class="sidebar-nav-item" data-tab="orders" onclick="switchTab('orders')">
          <span class="nav-icon">📋</span> 订单记录
        </a>
        <a class="sidebar-nav-item" data-tab="dishes" onclick="switchTab('dishes')">
          <span class="nav-icon">📝</span> 菜品审核
        </a>
        <a class="sidebar-nav-item" data-tab="settings" onclick="switchTab('settings')">
          <span class="nav-icon">⚙️</span> 系统设置
        </a>
      </nav>
    </aside>

    <!-- 主内容区 -->
    <main class="dashboard-main">
      <!-- 顶部栏 -->
      <header class="dashboard-topbar">
        <div style="display:flex;align-items:center;gap:12px;">
          <button class="topbar-hamburger" id="hamburger-btn" onclick="toggleSidebar()" aria-label="菜单">☰</button>
          <span class="topbar-greeting">你好，<strong>管理员</strong></span>
        </div>
        <div style="display:flex;align-items:center;gap:16px;">
          <span class="topbar-uptime" id="topbar-uptime">运行中...</span>
          <span class="topbar-clock" id="topbar-clock">00:00:00</span>
          <button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()" title="切换亮色/深色模式">
            <span id="theme-icon">☀️</span>
          </button>
          <div class="topbar-actions">
            <a href="/dashboard/logout" class="btn btn-outline btn-sm">退出</a>
          </div>
        </div>
      </header>

      <!-- 面包屑 -->
      <div class="dashboard-breadcrumb" id="breadcrumb">
        首页<span class="breadcrumb-sep">›</span><span class="breadcrumb-current" id="breadcrumb-current">数据概览</span>
      </div>

      <!-- 内容区 -->
      <div class="dashboard-content">

        <!-- ====== 数据概览 Tab ====== -->
        <div class="dashboard-tab active" id="tab-overview">

          <!-- 4 张统计卡片 -->
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card-label">总用户数</div>
              <div class="stat-card-value" id="stat-users">-</div>
              <div class="stat-card-spark" id="spark-users"></div>
            </div>
            <div class="stat-card">
              <div class="stat-card-label">家庭组数</div>
              <div class="stat-card-value" id="stat-families">-</div>
              <div class="stat-card-spark" id="spark-families"></div>
            </div>
            <div class="stat-card">
              <div class="stat-card-label">今日订单</div>
              <div class="stat-card-value" id="stat-orders">-</div>
              <div class="stat-card-spark" id="spark-orders"></div>
            </div>
            <div class="stat-card">
              <div class="stat-card-label">活跃家庭组</div>
              <div class="stat-card-value" id="stat-active-families">-</div>
              <div class="stat-card-sub">本周有订单</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-label">活跃订单</div>
              <div class="stat-card-value" id="stat-active-orders">-</div>
              <div class="stat-card-sub">看板可见</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-label">已归档订单</div>
              <div class="stat-card-value" id="stat-archived">-</div>
              <div class="stat-card-sub">历史保存</div>
            </div>
          </div>

          <!-- AI 智能建议 -->
          <div class="card" style="margin-bottom:16px;">
            <div class="card-header">💡 智能建议</div>
            <div class="card-body">
              <div class="suggestion-list" id="suggestions-list">
                <div class="loading-text">分析中...</div>
              </div>
            </div>
          </div>

          <!-- Bento Grid：趋势图 + 动态墙 -->
          <div class="bento-grid">
            <!-- 左：近7天趋势 + 热门菜品 -->
            <div class="bento-card bento-full" style="grid-column:1/span 1;">
              <div class="bento-card-header">📈 近 7 天订单趋势</div>
              <div class="bento-card-body">
                <div class="bar-chart-wrap">
                  <div class="bar-chart" id="trend-chart">
                    <div class="loading-text">加载中...</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- 右：实时动态墙 -->
            <div class="bento-card">
              <div class="bento-card-header">
                <span>🔔 实时动态</span>
                <div class="toolbar-filter">
                  <select id="live-feed-filter" onchange="loadLiveFeed()">
                    <option value="">全部</option>
                    <option value="点菜">点菜</option>
                    <option value="烹饪">烹饪</option>
                    <option value="系统">系统</option>
                  </select>
                </div>
              </div>
              <div class="bento-card-body" style="padding:10px 20px;">
                <div class="live-banner" id="live-banner" onclick="loadLiveFeed()">
                  有新的动态 ↑ 点击查看
                </div>
                <div class="timeline" id="live-feed">
                  <div class="loading-text">加载中...</div>
                </div>
              </div>
            </div>

            <!-- 热门菜品 Top 5 -->
            <div class="bento-card">
              <div class="bento-card-header">🏆 热门菜品 Top 5</div>
              <div class="bento-card-body">
                <div class="hbar-list" id="hot-dishes-list">
                  <div class="loading-text">加载中...</div>
                </div>
              </div>
            </div>

            <!-- 家庭组活跃排行 -->
            <div class="bento-card">
              <div class="bento-card-header">👨‍👩‍👧 家庭组活跃排行</div>
              <div class="bento-card-body" id="family-ranking">
                <div class="loading-text">加载中...</div>
              </div>
            </div>

            <!-- 用户活跃时段热力图 -->
            <div class="bento-card bento-full">
              <div class="bento-card-header">⏰ 用户活跃时段热力图（近7天）</div>
              <div class="bento-card-body" id="heatmap-container">
                <div class="loading-text">加载中...</div>
              </div>
            </div>
          </div>

          <!-- 最新注册用户 -->
          <div class="card">
            <div class="card-header">最新注册用户</div>
            <div class="card-body" style="padding:0;">
              <div class="data-table-wrap">
                <table class="data-table">
                  <thead>
                    <tr><th>手机号</th><th>角色</th><th>注册时间</th><th>状态</th></tr>
                  </thead>
                  <tbody id="recent-users-tbody">
                    <tr><td colspan="4" class="loading-text">加载中...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- ====== 用户管理 Tab ====== -->
        <div class="dashboard-tab" id="tab-users">
          <div class="toolbar">
            <div class="toolbar-search">
              <span class="toolbar-search-icon">🔍</span>
              <input type="text" id="user-search" placeholder="按手机号搜索..." oninput="loadUserPage(1)">
            </div>
            <div class="toolbar-filter">
              <select id="user-role-filter" onchange="loadUserPage(1)">
                <option value="">全部角色</option>
                <option value="chef">大厨</option>
                <option value="member">点菜员</option>
              </select>
            </div>
          </div>

          <div class="card" style="margin-bottom:0;">
            <div class="card-body" style="padding:0;">
              <div class="data-table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>手机号</th>
                      <th>角色</th>
                      <th>注册时间</th>
                      <th>家庭组</th>
                      <th>状态</th>
                      <th>操作</th>
                    </tr>
                  </thead>
                  <tbody id="users-tbody">
                    <tr><td colspan="7" class="loading-text">加载中...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          <div class="pagination" id="users-pagination"></div>
        </div>

        <!-- ====== 家庭组管理 Tab ====== -->
        <div class="dashboard-tab" id="tab-families">
          <div class="toolbar">
            <div class="toolbar-search">
              <span class="toolbar-search-icon">🔍</span>
              <input type="text" id="family-search" placeholder="按组名或邀请码搜索..." oninput="loadFamilyPage(1)">
            </div>
          </div>

          <div class="card" style="margin-bottom:0;">
            <div class="card-body" style="padding:0;">
              <div class="data-table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>组名</th>
                      <th>邀请码</th>
                      <th>成员数</th>
                      <th>创建时间</th>
                      <th>状态</th>
                      <th>操作</th>
                    </tr>
                  </thead>
                  <tbody id="families-tbody">
                    <tr><td colspan="7" class="loading-text">加载中...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          <div class="pagination" id="families-pagination"></div>
        </div>

        <!-- ====== 订单记录 Tab ====== -->
        <!-- ====== 订单记录 Tab (生命周期管理) ====== -->
        <div class="dashboard-tab" id="tab-orders">
          <!-- 子 Tab 切换 -->
          <div class="toolbar" style="margin-bottom:12px;">
            <button class="btn btn-sm lifecycle-tab active" data-lc="active" onclick="switchLifecycle('active')">活跃订单</button>
            <button class="btn btn-sm btn-outline lifecycle-tab" data-lc="archived" onclick="switchLifecycle('archived')">已归档</button>
            <button class="btn btn-sm btn-outline lifecycle-tab" data-lc="deleted" onclick="switchLifecycle('deleted')">已软删除</button>
            <span style="flex:1;"></span>
            <button class="btn btn-sm btn-outline" id="lc-batch-btn" style="display:none;" onclick="lifecycleBatch()">批量操作</button>
          </div>

          <div class="card" style="margin-bottom:0;">
            <div class="card-body" style="padding:0;">
              <div class="data-table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>订单ID</th>
                      <th>手机号</th>
                      <th>菜品</th>
                      <th>状态</th>
                      <th>时间</th>
                      <th>操作</th>
                    </tr>
                  </thead>
                  <tbody id="orders-tbody">
                    <tr><td colspan="6" class="loading-text">加载中...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          <div class="pagination" id="orders-pagination"></div>
        </div>

        <!-- ====== 菜品审核 Tab ====== -->
        <div class="dashboard-tab" id="tab-dishes">
          <div class="toolbar">
            <div class="toolbar-search">
              <span class="toolbar-search-icon">🔍</span>
              <input type="text" id="dish-search" placeholder="按菜品名称搜索..." oninput="loadDishPage(1)">
            </div>
          </div>

          <div class="card" style="margin-bottom:0;">
            <div class="card-body" style="padding:0;">
              <div class="data-table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>菜品名称</th>
                      <th>所属家庭组</th>
                      <th>分类</th>
                      <th>评分</th>
                      <th>状态</th>
                    </tr>
                  </thead>
                  <tbody id="dishes-tbody">
                    <tr><td colspan="6" class="loading-text">加载中...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          <div class="pagination" id="dishes-pagination"></div>
        </div>

        <!-- ====== 系统设置 Tab — Core Console ====== -->
        <div class="dashboard-tab core-console" id="tab-settings">

          <!-- Bento Grid -->
          <div class="cc-grid">

            <!-- ====== 主控节点 (2/3) ====== -->
            <div class="cc-card">
              <div class="cc-card-header"><span class="cc-dot"></span> PRIMARY NODE — 今日运营概览</div>
              <div class="cc-primary">
                <!-- 环形进度器 — 系统运行时长 -->
                <div class="cc-ring-wrap">
                  <svg class="cc-ring-svg" viewBox="0 0 170 170">
                    <circle class="cc-ring-bg" cx="85" cy="85" r="78"/>
                    <circle class="cc-ring-fg" id="cc-uptime-ring" cx="85" cy="85" r="78"
                      stroke-dasharray="490" stroke-dashoffset="490"/>
                  </svg>
                  <div class="cc-ring-center">
                    <span class="cc-ring-value" id="cc-uptime-val">--:--:--</span>
                    <span class="cc-ring-label">UPTIME</span>
                  </div>
                </div>
                <!-- 业务 KPI -->
                <div class="cc-kpi-grid" id="cc-kpi-grid">
                  <div class="cc-kpi-item">
                    <div class="cc-kpi-value" id="cc-kpi-new-users">-</div>
                    <div class="cc-kpi-label">今日新增用户</div>
                    <div class="cc-kpi-trend" id="cc-kpi-new-users-trend"></div>
                  </div>
                  <div class="cc-kpi-item">
                    <div class="cc-kpi-value" id="cc-kpi-orders">-</div>
                    <div class="cc-kpi-label">今日点菜次数</div>
                    <div class="cc-kpi-trend" id="cc-kpi-orders-trend"></div>
                  </div>
                  <div class="cc-kpi-item">
                    <div class="cc-kpi-value" id="cc-kpi-cooking">-</div>
                    <div class="cc-kpi-label">正在烹饪中</div>
                    <div class="cc-kpi-sub">🔥 实时</div>
                  </div>
                  <div class="cc-kpi-item">
                    <div class="cc-kpi-value" id="cc-kpi-completed">-</div>
                    <div class="cc-kpi-label">今日已完成</div>
                    <div class="cc-kpi-trend" id="cc-kpi-completed-trend"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- ====== 订单完成率 (1/3) ====== -->
            <div class="cc-card cc-health">
              <div class="cc-card-header"><span class="cc-dot"></span> ORDER COMPLETION</div>
              <div class="cc-health-ring">
                <svg class="cc-health-svg" viewBox="0 0 120 120">
                  <circle class="cc-health-bg" cx="60" cy="60" r="54"/>
                  <circle class="cc-health-fg" id="cc-health-ring" cx="60" cy="60" r="54"
                    stroke-dasharray="339" stroke-dashoffset="339"/>
                </svg>
                <div class="cc-health-center">
                  <span class="cc-health-value" id="cc-health-val">--</span>
                  <span class="cc-health-label">% 完成率</span>
                </div>
              </div>
              <div style="text-align:center;font-size:11px;color:var(--dbg-text-muted);margin-top:8px;">
                已完成 <span id="cc-completed-count">0</span> / 共 <span id="cc-total-count">0</span> 单
              </div>
            </div>

            <!-- ====== 业务动态 (1/3) ====== -->
            <div class="cc-card">
              <div class="cc-card-header"><span class="cc-dot"></span> LIVE ACTIVITY — 业务动态</div>
              <div class="cc-matrix" style="height:170px;">
                <div class="cc-matrix-inner" id="cc-matrix-log"></div>
              </div>
            </div>

            <!-- ====== 数据中心 (全宽) ====== -->
            <div class="cc-card cc-full">
              <div class="cc-card-header"><span class="cc-dot"></span> DATA CENTER — 数据中心</div>
              <div class="cc-datacenter">
                <!-- 本周热门菜品 Top 5 -->
                <div>
                  <div style="font-size:11px;color:var(--dbg-text-muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:1px;">本周热门菜品 Top 5</div>
                  <div class="cc-hot-dishes" id="cc-hot-dishes"></div>
                </div>
                <!-- 最近7天订单趋势 -->
                <div>
                  <div style="font-size:11px;color:var(--dbg-text-muted);margin-bottom:10px;text-transform:uppercase;letter-spacing:1px;">近7天订单趋势</div>
                  <div class="cc-trend-chart" id="cc-trend-chart">
                    <div class="loading-text">加载中...</div>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <!-- ====== 生命周期配置 ====== -->
          <div class="cc-card cc-settings-form">
            <div class="cc-card-header"><span class="cc-dot"></span> LIFECYCLE CONFIG — 生命周期配置</div>
            <div class="card-body">
              <div class="settings-info-row"><span class="settings-label">自动归档</span><span class="settings-value">完成后 <strong>48 小时</strong> 自动归档（每小时检查一次）</span></div>
              <div class="settings-info-row"><span class="settings-label">自动软删除</span><span class="settings-value">归档 <strong>90 天</strong> 后自动软删除（每日凌晨 3 点）</span></div>
              <div class="settings-info-row"><span class="settings-label">看板订单上限</span><span class="settings-value">最多展示 <strong>50 条</strong> 活跃订单</span></div>
              <div class="settings-info-row"><span class="settings-label">每列显示上限</span><span class="settings-value">每列最多 <strong>10 条</strong>，超出可前往历史记录</span></div>
              <div class="settings-info-row"><span class="settings-label">归档位置</span><span class="settings-value">订单记录 → 已归档 Tab → 可恢复或软删除</span></div>
              <div class="settings-info-row"><span class="settings-label">恢复方式</span><span class="settings-value">数据管理 → 找到订单 → 点击「恢复」即可重新激活</span></div>
            </div>
          </div>

          <!-- ====== 密码修改 ====== -->
          <div class="cc-card cc-settings-form">
            <div class="cc-card-header"><span class="cc-dot"></span> ACCESS CONTROL</div>
            <form id="password-form" onsubmit="changePassword(event)" style="max-width:400px;">
              <div class="form-group">
                <label class="form-label">旧密码</label>
                <input type="password" class="form-input" id="old-password" required>
              </div>
              <div class="form-group">
                <label class="form-label">新密码</label>
                <input type="password" class="form-input" id="new-password" required minlength="6" placeholder="至少6位">
              </div>
              <div style="margin-top:16px;">
                <button type="submit" class="btn btn-primary">保存修改</button>
              </div>
              <div id="password-msg" style="margin-top:8px;font-size:13px;"></div>
            </form>
          </div>

        </div>

        <!-- ====== 成员列表模态窗口 ====== -->
        <div class="modal-overlay" id="members-modal" style="display:none;">
          <div class="modal-box">
            <div class="modal-header">
              <span class="modal-title" id="members-modal-title">成员列表</span>
              <button class="modal-close" onclick="closeMembersModal()">&times;</button>
            </div>
            <div class="modal-body" id="members-modal-body">
              <div class="loading-text">加载中...</div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>

  <script>
  // ===== 侧边栏切换 =====
  function toggleSidebar() {
    var sidebar = document.getElementById('sidebar');
    var overlay = document.getElementById('sidebar-overlay');
    var isOpen = sidebar.classList.contains('open');
    if (isOpen) {
      sidebar.classList.remove('open');
      overlay.classList.remove('show');
    } else {
      sidebar.classList.add('open');
      overlay.classList.add('show');
    }
  }

  document.getElementById('sidebar-overlay').addEventListener('click', function() {
    document.getElementById('sidebar').classList.remove('open');
    this.classList.remove('show');
  });

  document.getElementById('members-modal').addEventListener('click', function(e) {
    if (e.target === this) closeMembersModal();
  });

  // ===== Tab 切换 =====
  var TAB_NAMES = {
    overview: '数据概览', users: '用户管理', families: '家庭组管理',
    orders: '订单记录', dishes: '菜品审核', settings: '系统设置'
  };
  var currentTab = 'overview';

  function switchTab(tab) {
    currentTab = tab;
    // 更新侧边栏
    document.querySelectorAll('.sidebar-nav-item').forEach(function(el) {
      el.classList.toggle('active', el.dataset.tab === tab);
    });
    // 更新内容区
    document.querySelectorAll('.dashboard-tab').forEach(function(el) {
      el.classList.toggle('active', el.id === 'tab-' + tab);
    });
    // 更新面包屑
    document.getElementById('breadcrumb-current').textContent = TAB_NAMES[tab] || tab;
    // 按需首次加载
    if (tab === 'users' && !window._usersLoaded) { window._usersLoaded = true; loadUserPage(1); }
    if (tab === 'families' && !window._familiesLoaded) { window._familiesLoaded = true; loadFamilyPage(1); }
    if (tab === 'orders' && !window._ordersLoaded) { window._ordersLoaded = true; loadOrderPage(1); }
    if (tab === 'dishes' && !window._dishesLoaded) { window._dishesLoaded = true; loadDishPage(1); }
    if (tab === 'settings' && !window._settingsLoaded) { window._settingsLoaded = true; loadSettings(); }
    // 移动端关闭侧边栏
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebar-overlay').classList.remove('show');
  }

  // ===== 数字动画 =====
  function animateNumber(el, target) {
    // 兜底：undefined/null/NaN → 0
    target = Number(target) || 0;
    var start = 0;
    var duration = 800;
    var startTime = null;
    function step(ts) {
      if (!startTime) startTime = ts;
      var progress = Math.min((ts - startTime) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(eased * target);
      if (progress < 1) requestAnimationFrame(step);
      else el.textContent = target;
    }
    requestAnimationFrame(step);
  }

  // 迷你趋势条
  function renderSparkBars(id, count, total) {
    var el = document.getElementById(id);
    if (!el) return;
    var bars = '';
    for (var i = 0; i < 4; i++) {
      var h = 6 + Math.random() * 18;
      bars += '<span class="stat-card-spark-bar" style="height:' + h + 'px;"></span>';
    }
    el.innerHTML = bars;
  }

