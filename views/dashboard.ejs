  // ====== 启用/禁用用户 ======
  function toggleUserStatus(userId, action) {
    var msg = action === 'disable' ? '确定要禁用该用户吗？禁用后该用户将无法登录。' : '确定要启用该用户吗？';
    if (!confirm(msg)) return;
    fetch('/api/dashboard/users/' + userId + '/' + action, { method: 'PUT' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.error) { alert(d.error); return; }
        loadUserPage(window._currentUserPage || 1);
      })
      .catch(function() { alert('操作失败'); });
  }

  // ====== 删除用户 ======
  function deleteUser(userId, phone) {
    if (!confirm('确定要删除用户 ' + phone + ' 吗？\n\n此操作不可撤销，将物理删除该用户及其关联数据。')) return;
    fetch('/api/dashboard/users/' + userId, { method: 'DELETE' }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.error) { alert(d.error); return; }
      alert('已删除');
      loadUserPage(window._currentUserPage || 1);
    }).catch(function() { alert('删除失败'); });
  }

  // ====== 删除家庭组 ======
  function deleteFamily(fid, name) {
    if (!confirm('确定要删除家庭组「' + name + '」吗？\n\n此操作将解散该家庭组，所有成员的归属关系将被清除。')) return;
    fetch('/api/dashboard/families/' + fid, { method: 'DELETE' }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.error) { alert(d.error); return; }
      alert('已删除');
      loadFamilyPage(window._currentFamilyPage || 1);
    }).catch(function() { alert('删除失败'); });
  }

  // ====== 查看家庭组成员 ======
  function viewFamilyMembers(fid, name) {
    var modal = document.getElementById('members-modal');
    var body = document.getElementById('members-modal-body');
    document.getElementById('members-modal-title').textContent = '「' + name + '」成员列表';
    body.innerHTML = '<div class="loading-text">加载中...</div>';
    modal.style.display = 'flex';
    fetch('/api/dashboard/family/' + fid + '/members').then(function(r) { return r.json(); }).then(function(d) {
      var members = d.members || [];
      if (members.length === 0) {
        body.innerHTML = '<div class="empty-text">暂未加入成员</div>';
        return;
      }
      body.innerHTML = '<table class="data-table"><thead><tr><th>手机号</th><th>角色</th><th>加入时间</th></tr></thead><tbody>'
        + members.map(function(m) {
          var roleText = m.role === 'chef' ? '大厨' : '点菜员';
          return '<tr><td>' + escapeHtml(m.phone) + '</td><td>' + roleText + '</td><td>' + escapeHtml(formatTime(m.createdAt)) + '</td></tr>';
        }).join('')
        + '</tbody></table>';
    }).catch(function() {
      body.innerHTML = '<div class="empty-text">加载失败</div>';
    });
  }

  function closeMembersModal() {
    document.getElementById('members-modal').style.display = 'none';
  }

  // ====== 订单记录 ======
  // ====== 订单生命周期管理 ======
  var _lcScope = 'active'; // active | archived | deleted
  function switchLifecycle(scope) {
    _lcScope = scope;
    document.querySelectorAll('.lifecycle-tab').forEach(function(b) { b.classList.remove('active'); b.classList.add('btn-outline'); });
    var activeBtn = document.querySelector('.lifecycle-tab[data-lc="' + scope + '"]');
    if (activeBtn) { activeBtn.classList.add('active'); activeBtn.classList.remove('btn-outline'); }
    var batchBtn = document.getElementById('lc-batch-btn');
    batchBtn.style.display = (scope === 'active') ? '' : 'none';
    batchBtn.textContent = '批量归档 completed';
    loadOrderPage(1);
  }
  function lifecycleBatch() {
    if (!confirm('确定批量归档所有 completed 订单吗？')) return;
    fetch('/api/dashboard/data/batch-archive', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: 'completed' }) })
      .then(function(r) { return r.json(); }).then(function(d) { alert(d.message); loadOrderPage(1); });
  }
  function loadOrderPage(page) {
    window._currentOrderPage = page;
    var tbody = document.getElementById('orders-tbody');
    tbody.innerHTML = '<tr><td colspan="6" class="loading-text">加载中...</td></tr>';
    var apiMap = { active: '/api/dashboard/orders', archived: '/api/dashboard/data/archived', deleted: '/api/dashboard/data/deleted' };
    var url = (apiMap[_lcScope] || apiMap.active) + '?page=' + page + '&limit=20';
    fetch(url).then(function(r) { return r.json(); }).then(function(d) {
      var orders = d.orders || [];
      if (orders.length === 0) { tbody.innerHTML = '<tr><td colspan="6" class="empty-text">暂无数据</td></tr>'; renderPagination('orders-pagination', 0, 0, 0, loadOrderPage, 'loadOrderPage'); return; }
      tbody.innerHTML = orders.map(function(o) {
        var timeField = o.archivedAt || o.deletedAt || o.createdAt;
        var actionHtml = '';
        if (_lcScope === 'active') {
          actionHtml = '<button class="btn btn-outline btn-xs" onclick="lifecycleAction(\'archive\',' + o.id + ')">归档</button>';
        } else if (_lcScope === 'archived') {
          actionHtml = '<button class="btn btn-outline btn-xs" onclick="lifecycleAction(\'restore\',' + o.id + ')">恢复</button> <button class="btn btn-danger btn-xs" onclick="lifecycleAction(\'softdelete\',' + o.id + ')">软删除</button>';
        } else {
          actionHtml = '<button class="btn btn-outline btn-xs" onclick="lifecycleAction(\'restore\',' + o.id + ')">恢复</button> <button class="btn btn-danger btn-xs" onclick="if(confirm(\"永久删除不可恢复，确定？\"))lifecycleAction(\'permanent\',' + o.id + ')">永久删除</button>';
        }
        return '<tr><td>#' + o.id + '</td><td>' + escapeHtml(o.phone || '') + '</td><td>' + (o.dishNames ? escapeHtml(o.dishNames.join('、')) : '-') + '</td><td>' + escapeHtml(o.status || '') + '</td><td>' + escapeHtml(formatTime(timeField)) + '</td><td>' + actionHtml + '</td></tr>';
      }).join('');
      renderPagination('orders-pagination', d.page, d.totalPages, d.total, loadOrderPage, 'loadOrderPage');
    }).catch(function() { tbody.innerHTML = '<tr><td colspan="6" class="empty-text">加载失败</td></tr>'; });
  }
  function lifecycleAction(action, id) {
    var endpoints = {
      archive:  ['PUT', '/api/dashboard/data/restore/' + id + '/archive'], // uses individual archive
      restore:  ['PUT', '/api/dashboard/data/restore/' + id],
      softdelete: ['PUT', '/api/dashboard/data/batch-softdelete'], // individual via body not built — use archive then batch
    };
    // 简化：archive 和 restore 直接调
    if (action === 'archive') {
      fetch('/api/orders/archive/' + id, { method: 'PUT' }).then(function(r){return r.json();}).then(function(d){ alert(d.message); loadOrderPage(window._currentOrderPage || 1); });
    } else if (action === 'restore') {
      fetch('/api/dashboard/data/restore/' + id, { method: 'PUT' }).then(function(r){return r.json();}).then(function(d){ alert(d.message); loadOrderPage(window._currentOrderPage || 1); });
    } else if (action === 'softdelete') {
      if (!confirm('确定软删除该订单？')) return;
      fetch('/api/dashboard/data/restore/' + id, { method: 'PUT' }).then(function(){ return fetch('/api/dashboard/data/batch-softdelete', { method: 'PUT' }); }).then(function(r){return r.json();}).then(function(d){ alert(d.message); loadOrderPage(window._currentOrderPage || 1); });
    } else if (action === 'permanent') {
      fetch('/api/dashboard/data/permanent/' + id, { method: 'DELETE' }).then(function(r){return r.json();}).then(function(d){ alert(d.message); loadOrderPage(window._currentOrderPage || 1); });
    }
  }

  function orderStatusName(s) {
    var map = { pending: '待接单', accepted: '已接单', cooking: '烹饪中', completed: '已完成', rejected: '已拒单' };
    return map[s] || s;
  }
  function orderStatusClass(s) {
    var map = { pending: 'status-pending', accepted: 'status-accepted', cooking: 'status-cooking', completed: 'status-completed', rejected: 'status-rejected' };
    return map[s] || '';
  }

  // ====== 菜品列表 ======
  function loadDishPage(page) {
    window._currentDishPage = page;
    var tbody = document.getElementById('dishes-tbody');
    tbody.innerHTML = '<tr><td colspan="6" class="loading-text">加载中...</td></tr>';
    var search = encodeURIComponent(document.getElementById('dish-search').value.trim());
    var qs = '?page=' + page + '&limit=20';
    if (search) qs += '&search=' + search;

    fetch('/api/dashboard/dishes' + qs).then(function(r) { return r.json(); }).then(function(d) {
      var dishes = d.dishes || [];
      if (dishes.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="empty-text">暂无数据</td></tr>';
      } else {
        tbody.innerHTML = dishes.map(function(d) {
          var availDot = d.isAvailable ? 'normal' : 'disabled';
          var availText = d.isAvailable ? '上架' : '下架';
          var stars = d.avgRating > 0 ? ' ⭐' + d.avgRating.toFixed(1) : ' 暂无';
          return '<tr>'
            + '<td>' + d.id + '</td>'
            + '<td>' + escapeHtml(d.name) + '</td>'
            + '<td>' + escapeHtml(d.familyName) + '</td>'
            + '<td>' + escapeHtml(d.category) + '</td>'
            + '<td>' + stars + '</td>'
            + '<td><span class="status-dot ' + availDot + '">' + availText + '</span></td>'
            + '</tr>';
        }).join('');
      }
      renderPagination('dishes-pagination', d.page, d.totalPages, d.total, loadDishPage, 'loadDishPage');
    }).catch(function() {
      tbody.innerHTML = '<tr><td colspan="6" class="empty-text">加载失败</td></tr>';
      document.getElementById('dishes-pagination').innerHTML = '';
    });
  }

  // ====== 系统设置 — Core Console ======
  var _ccUptimeInterval = null;
  var _ccStarted = false;

  function initCoreConsole() {
    if (_ccStarted) return;
    _ccStarted = true;

    // 获取上线日期 + 运营数据
    Promise.all([
      fetch('/api/dashboard/uptime').then(function(r) { return r.json(); }),
      fetch('/api/dashboard/stats').then(function(r) { return r.json(); }),
      fetch('/api/dashboard/insights').then(function(r) { return r.json(); }),
      fetch('/api/dashboard/trend').then(function(r) { return r.json(); }),
      fetch('/api/dashboard/live-feed').then(function(r) { return r.json(); }),
    ]).then(function(results) {
      var uptime = results[0];
      var stats = results[1];
      var insights = results[2];
      var trend = results[3];
      var liveFeed = results[4];

      var startTs = uptime.launchDate ? new Date(uptime.launchDate).getTime() : Date.now();
      startUptimeRing(startTs);
      renderBusinessKPIs(stats);
      animateCompletionRate(stats.completionRate || 0, stats.completedOrdersToday || 0, stats.todayOrders || 0);
      renderHotDishes(insights.hotDishes || []);
      renderTrendChart(trend.trend || []);
      renderLiveActivity(liveFeed.liveFeed || []);
    });
  }

  function startUptimeRing(launchTs) {
    var ring = document.getElementById('cc-uptime-ring');
    var valEl = document.getElementById('cc-uptime-val');
    var labelEl = document.querySelector('.cc-ring-label');
    var CIRC = 490;

    function tick() {
      var secs = Math.floor((Date.now() - launchTs) / 1000);
      var days = Math.floor(secs / 86400);
      var h = Math.floor((secs % 86400) / 3600);
      var m = Math.floor((secs % 3600) / 60);
      var s = secs % 60;
      var pad = function(n) { return n < 10 ? '0' + n : '' + n; };
      if (valEl) valEl.textContent = days + 'd ' + pad(h) + 'h ' + pad(m) + 'm';
      if (labelEl) labelEl.textContent = 'SINCE LAUNCH';

      // 环形进度：每小时一圈 (24小时 = 一天)
      var hourFrac = (h * 3600 + m * 60 + s) / 86400;
      if (ring) ring.setAttribute('stroke-dashoffset', CIRC * (1 - hourFrac));
    }
    tick();
    _ccUptimeInterval = setInterval(tick, 1000);
    _timers.push(_ccUptimeInterval);
  }

  function renderBusinessKPIs(stats) {
    animateKpiValue('cc-kpi-new-users', stats.newUsersToday || 0);
    animateKpiValue('cc-kpi-orders', stats.todayOrders || 0);
    animateKpiValue('cc-kpi-cooking', stats.cookingOrders || 0);
    animateKpiValue('cc-kpi-completed', stats.completedOrdersToday || 0);
  }

  function animateKpiValue(elId, target) {
    var el = document.getElementById(elId);
    if (!el) return;
    target = Number(target) || 0;
    var start = 0, startTime = null, duration = 800;
    function step(ts) {
      if (!startTime) startTime = ts;
      var p = Math.min((ts - startTime) / duration, 1);
      var eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.floor(eased * target);
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = target;
    }
    requestAnimationFrame(step);
  }

  function animateCompletionRate(rate, completed, total) {
    var ring = document.getElementById('cc-health-ring');
    var valEl = document.getElementById('cc-health-val');
    var CIRC = 339;
    var startTime = null;
    function step(ts) {
      if (!startTime) startTime = ts;
      var p = Math.min((ts - startTime) / 1200, 1);
      var v = (rate * (1 - Math.pow(1 - p, 3))).toFixed(1);
      if (valEl) valEl.textContent = v;
      if (ring) ring.setAttribute('stroke-dashoffset', CIRC * (1 - parseFloat(v) / 100));
      if (p < 1) requestAnimationFrame(step);
      else { if (valEl) valEl.textContent = rate; }
    }
    requestAnimationFrame(step);
    var compEl = document.getElementById('cc-completed-count');
    var totalEl = document.getElementById('cc-total-count');
    if (compEl) compEl.textContent = completed;
    if (totalEl) totalEl.textContent = total;
  }

  function renderHotDishes(dishes) {
    var container = document.getElementById('cc-hot-dishes');
    if (!container) return;
    if (!dishes || dishes.length === 0) {
      container.innerHTML = '<div class="empty-text" style="padding:20px;">暂无数据</div>';
      return;
    }
    var total = dishes.reduce(function(s, d) { return s + d.cnt; }, 0);
    var maxCnt = dishes[0] ? dishes[0].cnt : 1;
    var medals = ['🥇', '🥈', '🥉', '4', '5'];
    container.innerHTML = dishes.map(function(d, i) {
      var pct = Math.round((d.cnt / maxCnt) * 100);
      return '<div class="cc-hot-row">'
        + '<span class="cc-hot-rank">' + (medals[i] || (i + 1)) + '</span>'
        + '<span class="cc-hot-name">' + escapeHtml(d.name) + '</span>'
        + '<span class="cc-hot-track"><span class="cc-hot-fill" style="width:' + pct + '%"></span></span>'
        + '<span class="cc-hot-count">' + d.cnt + '单 ' + (total > 0 ? Math.round(d.cnt / total * 100) : 0) + '%</span>'
        + '</div>';
    }).join('');
  }

  function renderTrendChart(trendData) {
    var container = document.getElementById('cc-trend-chart');
    if (!container) return;
    if (!trendData || trendData.length === 0) {
      container.innerHTML = '<div class="empty-text" style="padding:20px;">暂无数据</div>';
      return;
    }
    var maxCount = 1;
    trendData.forEach(function(it) { if (it.count > maxCount) maxCount = it.count; });
    var dayNames = ['日','一','二','三','四','五','六'];
    container.innerHTML = '<div class="cc-bar-chart">'
      + trendData.map(function(it) {
          var pct = maxCount > 0 ? Math.round((it.count / maxCount) * 100) : 0;
          var d = new Date(it.date);
          return '<div class="cc-bar-col">'
            + '<span class="cc-bar-val">' + it.count + '</span>'
            + '<span class="cc-bar-bar" style="height:' + pct + '%"></span>'
            + '<span class="cc-bar-day">' + (d.getMonth()+1) + '/' + d.getDate() + '</span>'
            + '</div>';
        }).join('')
      + '</div>';
  }

  function renderLiveActivity(feed) {
    var el = document.getElementById('cc-matrix-log');
    if (!el) return;
    if (!feed || feed.length === 0) {
      el.innerHTML = '<div>暂无业务动态</div>';
      return;
    }
    // 取最新 10 条，复制一份用于无缝滚动
    var items = feed.slice(0, 10);
    var lines = items.map(function(it) {
      var typeTag = it.type === '点菜' ? '[点菜]' : (it.type === '评分' ? '[评分]' : (it.type === '注册' ? '[注册]' : '[' + it.type + ']'));
      var time = it.time ? it.time.substring(11, 16) : '';
      return '<div>' + time + ' ' + typeTag + ' ' + escapeHtml(it.desc) + '</div>';
    });
    el.innerHTML = lines.concat(lines).concat(lines).join('');
  }

  function loadSettings() {
    initCoreConsole();
  }


  function changePassword(e) {
    e.preventDefault();
    var msg = document.getElementById('password-msg');
    var oldPw = document.getElementById('old-password').value.trim();
    var newPw = document.getElementById('new-password').value.trim();

    if (newPw.length < 6) { msg.innerHTML = '<span style="color:#E57373;">新密码至少6位</span>'; return; }

    fetch('/api/dashboard/settings/password', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ oldPassword: oldPw, newPassword: newPw }),
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) {
        msg.innerHTML = '<span style="color:#8BAA7B;">密码修改成功</span>';
        document.getElementById('old-password').value = '';
        document.getElementById('new-password').value = '';
      } else {
        msg.innerHTML = '<span style="color:#E57373;">' + escapeHtml(d.message) + '</span>';
      }
    }).catch(function() {
      msg.innerHTML = '<span style="color:#E57373;">请求失败</span>';
    });
  }

  // ====== 定时器清理 ======
  window.addEventListener('beforeunload', function() {
    _timers.forEach(function(t) { clearInterval(t); });
  });

  // ====== 初始加载 ======
  loadOverview();
  </script>
<% } %>

</body>
</html>
