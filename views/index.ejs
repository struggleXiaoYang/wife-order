    <div id="remark-list"></div>
  </div>

  <!-- 底部浮窗 -->
  <div class="bottom-bar">
    <span class="count-text">已选 <strong class="count-num" id="count">0</strong> 道菜</span>
    <button class="submit-btn" id="submit-btn">提交点菜</button>
  </div>

  <script>
    // === 分类选项卡 ===
    (function() {
      var tabs = document.getElementById('category-tabs');
      var cards = document.querySelectorAll('.dish-card');
      var activeCat = '';

      function applyFilters() {
        var keyword = document.getElementById('search-box').value.trim().toLowerCase();
        var hasVisible = false;
        cards.forEach(function(card) {
          var matchCat = !activeCat || card.dataset.category === activeCat;
          var matchSearch = !keyword || card.querySelector('.dish-name').textContent.toLowerCase().indexOf(keyword) !== -1;
          var visible = matchCat && matchSearch;
          card.style.display = visible ? '' : 'none';
          if (visible) hasVisible = true;
        });
        document.getElementById('empty-filter-msg').style.display = (activeCat && !hasVisible) ? '' : 'none';
      }

      // 获取分类列表
      fetch('/api/menu')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          (data.categories || []).forEach(function(cat) {
            var btn = document.createElement('button');
            btn.className = 'tab-btn';
            btn.textContent = cat;
            btn.dataset.cat = cat;
            tabs.appendChild(btn);
          });
        });

      // 委托点击
      tabs.addEventListener('click', function(e) {
        var btn = e.target;
        if (!btn.classList.contains('tab-btn')) return;

        tabs.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');

        activeCat = btn.dataset.cat;
        applyFilters();
      });

      // 搜索
      document.getElementById('search-box').addEventListener('input', function() {
        applyFilters();
      });
    })();

    // === 点餐逻辑 ===
    var selected = {}; // { dishId: {id, name, remark} }

    function updateRemarkPanel() {
      var panel = document.getElementById('remark-panel');
      var list = document.getElementById('remark-list');
      var ids = Object.keys(selected);
      if (ids.length === 0) {
        panel.style.display = 'none';
        return;
      }
      panel.style.display = '';
      var html = '';
      ids.forEach(function(id) {
        var s = selected[id];
        html += '<div class="remark-row"><span class="remark-dish-name">' + escapeHtml(s.name) + '</span>'
          + '<input class="remark-input" type="text" data-id="' + id + '" placeholder="备注，如少放辣" value="' + escapeHtml(s.remark || '') + '" maxlength="200">'
          + '</div>';
      });
      list.innerHTML = html;
      // 绑定输入事件
      list.querySelectorAll('.remark-input').forEach(function(inp) {
        inp.addEventListener('input', function() {
          var sid = this.dataset.id;
          if (selected[sid]) selected[sid].remark = this.value;
        });
      });
    }

    document.querySelectorAll('.want-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = this.dataset.id;
        var name = this.closest('.dish-card').querySelector('.dish-name').textContent;
        var countEl = document.getElementById('count');
        if (selected[id]) {
          delete selected[id];
          this.textContent = '想吃';
          this.classList.remove('on');
        } else {
          selected[id] = { id: id, name: name, remark: '' };
          this.textContent = '取消';
          this.classList.add('on');

          // 飞行动画
          var btnRect = this.getBoundingClientRect();
          var endRect = countEl.getBoundingClientRect();
          var dx = endRect.left + endRect.width / 2 - (btnRect.left + btnRect.width / 2);
          var dy = endRect.top + endRect.height / 2 - (btnRect.top + btnRect.height / 2);

          var dot = document.createElement('div');
          dot.className = 'flying-dot';
          dot.style.left = (btnRect.left + btnRect.width / 2 - 15) + 'px';
          dot.style.top = (btnRect.top + btnRect.height / 2 - 15) + 'px';
          document.body.appendChild(dot);

          dot.animate([
            { transform: 'translate(0, 0) scale(1)', offset: 0 },
            { transform: 'translate(' + (dx * 0.35) + 'px, ' + (dy * 0.1) + 'px) scale(1.2)', offset: 0.35 },
            { transform: 'translate(' + dx + 'px, ' + dy + 'px) scale(0)', offset: 1 },
          ], { duration: 480, easing: 'cubic-bezier(0.25, 0.8, 0.25, 1)' }).onfinish = function() {
            dot.remove();
            countEl.style.transform = 'scale(1.55)';
            countEl.style.transition = 'transform 0.15s ease';
            setTimeout(function() { countEl.style.transform = 'scale(1)'; }, 180);
          };
        }
        var cnt = Object.keys(selected).length;
        countEl.textContent = cnt;
        updateRemarkPanel();
      });
    });

    // === 趣味大转盘 ===
    (function() {
      var dishes = [];
      document.querySelectorAll('.dish-card').forEach(function(card) {
        dishes.push({
          id: card.querySelector('.want-btn').dataset.id,
          name: card.querySelector('.dish-name').textContent,
          ingredients: card.querySelector('.dish-ingredients').textContent.replace('食材：', ''),
          image: card.querySelector('.dish-img') ? card.querySelector('.dish-img').src : '',
        });
      });

      var btn = document.getElementById('spin-btn');
      var hint = document.getElementById('spin-btn-hint');
      var overlay = document.getElementById('wheel-overlay');
      var canvas = document.getElementById('wheel-canvas');
      var ctx = canvas.getContext('2d');
      var startBtn = document.getElementById('wheel-start-btn');
      var closeBtn = document.getElementById('wheel-close');
      var resultDiv = document.getElementById('wheel-result');
      var resultImg = document.getElementById('wheel-result-img');
      var resultName = document.getElementById('wheel-result-name');
      var resultIngr = document.getElementById('wheel-result-ingredients');
      var resultMsg = document.getElementById('wheel-result-msg');
      var confirmBtn = document.getElementById('wheel-result-confirm');
      var respinBtn = document.getElementById('wheel-result-respin');
      var toast = document.getElementById('toast');

      var MSGS = [
        '天选之菜！就它了，不接受反驳 🙌',
        '命运的齿轮转向了它……认命吧 🍽️',
        '今天灶神爷钦点这道菜 🔥',
        '转盘说了算，不准挑食！😤',
      ];

      var COLORS = ['#FF7F50', '#ffb3ba', '#fff0ba', '#bae1ff', '#baffc9', '#ffd9b3', '#ffc3a0', '#f0d9ff'];

      if (dishes.length < 2) {
        btn.disabled = true;
        btn.classList.add('spin-btn-disabled');
        hint.style.display = '';
        return;
      }

      var N = dishes.length;
      var ARC = (2 * Math.PI) / N;
      var W = canvas.width, CX = W / 2, CY = W / 2, R = 130;
      var angle = 0, spinning = false;
      var animId = null;
      var winningIdx = -1;

      function drawWheel() {
        ctx.clearRect(0, 0, W, W);
        for (var i = 0; i < N; i++) {
          var start = angle + i * ARC;
          var end = start + ARC;
          ctx.beginPath();
          ctx.moveTo(CX, CY);
          ctx.arc(CX, CY, R, start, end);
          ctx.closePath();
          ctx.fillStyle = COLORS[i % COLORS.length];
          ctx.fill();
          ctx.strokeStyle = '#fff';
          ctx.lineWidth = 1.5;
          ctx.stroke();

          // 扇形文字
          ctx.save();
          ctx.translate(CX, CY);
          ctx.rotate(start + ARC / 2);
          ctx.textAlign = 'right';
          ctx.fillStyle = '#4a2f1a';
          ctx.font = 'bold 13px "PingFang SC","Microsoft YaHei",sans-serif';
          var txt = dishes[i].name.length > 4 ? dishes[i].name.slice(0, 4) + '…' : dishes[i].name;
          ctx.fillText(txt, R - 16, 5);
          ctx.restore();
        }

        // 圆心
        ctx.beginPath();
        ctx.arc(CX, CY, 28, 0, 2 * Math.PI);
        ctx.fillStyle = '#fff';
        ctx.fill();
        ctx.strokeStyle = '#FF7F50';
        ctx.lineWidth = 3;
        ctx.stroke();
        ctx.fillStyle = '#FF7F50';
        ctx.font = 'bold 11px "PingFang SC","Microsoft YaHei",sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('GO', CX, CY);
      }

      function spin() {
        if (spinning) return;
        spinning = true;
        startBtn.style.display = 'none';
        resultDiv.style.display = 'none';
        canvas.style.display = '';
        winningIdx = -1;

        // 归一化当前角度到 [0, 2π)，避免累计大数精度丢失
        angle = ((angle % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);

        // 随机 5~12 圈，连续均匀分布
        var extraRads = (5 + Math.random() * 7) * 2 * Math.PI;
        var targetAngle = angle + extraRads;
        var startAngle = angle;
        var duration = 3800;
        var startTime = performance.now();

        function anim(now) {
          var elapsed = now - startTime;
          var t = Math.min(elapsed / duration, 1);
          var ease = 1 - Math.pow(1 - t, 3);
          angle = startAngle + (targetAngle - startAngle) * ease;
          drawWheel();

          if (t < 1) {
            animId = requestAnimationFrame(anim);
          } else {
            spinning = false;
            angle = ((targetAngle % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
            drawWheel();

            // 指针固定在 12 点钟方向
            // Canvas: 0=3点钟, π/2=6点, π=9点, 3π/2=12点
            var pointerAngle = Math.PI * 1.5;
            // 从扇区0起点(angle)到指针的角位移
            var offset = ((pointerAngle - angle) % (2 * Math.PI) + 2 * Math.PI) % (2 * Math.PI);
            // 该位移落在第几个扇区
            winningIdx = Math.floor(offset / ARC);
            // 浮点边界保护：确保 idx 在 [0, N-1]
            if (winningIdx >= N) winningIdx = N - 1;
            if (winningIdx < 0) winningIdx = 0;

            var flashes = 0;
            var origColor = COLORS[winningIdx % COLORS.length];
            function flash() {
              if (flashes >= 6) {
                showResult();
                return;
              }
              var hi = flashes % 2 === 0;
              COLORS[winningIdx % COLORS.length] = hi ? '#ffeb3b' : origColor;
              drawWheel();
              flashes++;
              setTimeout(flash, 250);
            }
            flash();
          }
        }

        animId = requestAnimationFrame(anim);
      }

      function showResult() {
        canvas.style.display = 'none';
        resultDiv.style.display = '';
        var dish = dishes[winningIdx];
        resultName.textContent = dish.name;
        resultIngr.textContent = '食材：' + dish.ingredients;
        resultMsg.textContent = MSGS[Math.floor(Math.random() * MSGS.length)];
        resultImg.textContent = dish.image ? '' : '🍽️';
        if (dish.image) {
          var img = document.createElement('img');
          img.src = dish.image;
          img.style.width = '100%';
          img.style.height = '100%';
          img.style.objectFit = 'cover';
          img.style.borderRadius = '8px';
          img.onerror = function() { resultImg.textContent = '🍽️'; };
          resultImg.innerHTML = '';
          resultImg.appendChild(img);
        }
        startBtn.style.display = 'none';
      }

      function showToast(msg) {
        toast.textContent = msg;
        toast.style.display = '';
        toast.classList.remove('toast-show');
        void toast.offsetWidth;
        toast.classList.add('toast-show');
        setTimeout(function() { toast.style.display = 'none'; }, 2000);
      }

      btn.addEventListener('click', function() {
        overlay.style.display = 'flex';
        resultDiv.style.display = 'none';
        canvas.style.display = '';
        startBtn.style.display = '';
        angle = 0;
        drawWheel();
      });

      closeBtn.addEventListener('click', function() {
        overlay.style.display = 'none';
        if (animId) cancelAnimationFrame(animId);
        spinning = false;
      });

      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) {
          overlay.style.display = 'none';
          if (animId) cancelAnimationFrame(animId);
          spinning = false;
        }
      });

      startBtn.addEventListener('click', spin);
      respinBtn.addEventListener('click', function() {
        resultDiv.style.display = 'none';
        canvas.style.display = '';
        startBtn.style.display = '';
        angle = 0;
        drawWheel();
        spin();
      });

      confirmBtn.addEventListener('click', function() {
        var dish = dishes[winningIdx];
        var id = dish.id;
        selected[id] = { id: id, name: dish.name, remark: '' };
        updateRemarkPanel();
        var wb = document.querySelector('.want-btn[data-id="' + id + '"]');
        if (wb) { wb.textContent = '取消'; wb.classList.add('on'); }
        document.getElementById('count').textContent = Object.keys(selected).length;
        overlay.style.display = 'none';
        if (animId) cancelAnimationFrame(animId);
        spinning = false;
        showToast('已加入点餐单～');
      });

      drawWheel();
    })();

    document.getElementById('submit-btn').addEventListener('click', function() {
      var selKeys = Object.keys(selected);
      if (selKeys.length === 0) {
        alert('还没选菜呢～');
        return;
      }

      var items = selKeys.map(function(k) {
        return { dishId: selected[k].id, remark: selected[k].remark || '' };
      });

      fetch('/api/order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.success) {
            // 采购清单弹窗
            if (data.shoppingList && data.shoppingList.length > 0) {
              (function showShoppingList() {
                var shopOverlay = document.createElement('div');
                shopOverlay.className = 'shop-overlay';
                var shopCard = document.createElement('div');
                shopCard.className = 'shop-card';
                shopCard.innerHTML = '<h2 class=\"shop-title\">📋 今日采购清单</h2>'
                  + '<div class=\"shop-list\">'
                  + data.shoppingList.map(function(it, i) { return '<span class=\"shop-item\">' + (i + 1) + '. ' + it + '</span>'; }).join('')
                  + '</div>'
                  + '<button class=\"shop-close-btn\">知道了，去买菜 🛒</button>';
                shopOverlay.appendChild(shopCard);
                document.body.appendChild(shopOverlay);
                var closeBtn = shopCard.querySelector('.shop-close-btn');
                closeBtn.addEventListener('click', function() { shopOverlay.remove(); });
                shopOverlay.addEventListener('click', function(e) { if (e.target === shopOverlay) shopOverlay.remove(); });
              })();
            }

            // 飘心庆祝
            (function celebrate() {
              var PHRASES = [
                '今晚菜单已经安排好啦 ✨',
                '老公收到！准备大展身手 🔥',
                '坐等投喂吧～😋',
                '今天也是被爱的一天 💕',
              ];
              var HEART_COLORS = ['#ff6b8a', '#FF7F50', '#ff4d6d', '#ffb3ba', '#ff8a80', '#f48fb1'];

              var overlay = document.createElement('div');
              overlay.className = 'celebrate-overlay';
              document.body.appendChild(overlay);

              // 随机文案
              var text = document.createElement('div');
              text.className = 'celebrate-text';
              text.textContent = PHRASES[Math.floor(Math.random() * PHRASES.length)];
              overlay.appendChild(text);

              // 飘心
              var vw = window.innerWidth;
              var vh = window.innerHeight;
              var count = 5 + Math.floor(Math.random() * 4); // 5~8
              for (var i = 0; i < count; i++) {
                var heart = document.createElement('div');
                heart.className = 'floating-heart';
                heart.textContent = '❤️';
                heart.style.left = (vw * 0.15 + Math.random() * vw * 0.7) + 'px';
                heart.style.bottom = '0px';
                heart.style.fontSize = (20 + Math.random() * 30) + 'px';
                heart.style.color = HEART_COLORS[Math.floor(Math.random() * HEART_COLORS.length)];
                var wiggle = (Math.random() - 0.5) * 60;
                var rise = -(vh * 0.7 + Math.random() * vh * 0.3);
                var dur = 2000 + Math.random() * 1000;
                heart.style.animationDuration = dur + 'ms';
                heart.style.setProperty('--wiggle', wiggle + 'px');
                heart.style.setProperty('--rise', rise + 'px');
                overlay.appendChild(heart);
              }

              // 清理
              setTimeout(function() {
                overlay.remove();
                selected = {};
                updateRemarkPanel();
                document.querySelectorAll('.want-btn').forEach(function(b) { b.textContent = '想吃'; b.classList.remove('on'); });
                document.getElementById('count').textContent = 0;
              }, 2600);
            })();
          }
        }).catch(function() {
          var t = document.getElementById('toast');
          if (t) { t.textContent = '网络错误，请稍后重试'; t.style.display = ''; t.classList.remove('toast-show'); void t.offsetWidth; t.classList.add('toast-show'); setTimeout(function() { t.style.display = 'none'; }, 2500); }
        });
    });
  </script>
  <% } %>

  <!-- ====== 今日一屏 JS（厨师和点菜员共享） ====== -->
  <script>
  (function() {
    // 时间感知问候
    var hour = new Date().getHours();
    var greeting = '晚上好 🌙';
    if (hour >= 5 && hour < 12) greeting = '早上好 ☀️';
    else if (hour >= 12 && hour < 18) greeting = '中午好 🌤️';
    document.getElementById('greeting-text').textContent = greeting;

    // 加载推荐
    loadRecommendations();

    // 检查实时状态
    checkKitchenStatus();
  })();

  function loadRecommendations() {
    fetch('/api/recommend/today')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var grid = document.getElementById('recommend-grid');
        var list = d.recommendations || [];
        if (list.length === 0) {
          grid.innerHTML = '<div class="recommend-empty">暂无推荐菜品，先让大厨添加几道菜吧~</div>';
          return;
        }
        grid.innerHTML = list.map(function(item, i) {
          var badge = i === 0 ? '🏆 首选' : (i === 1 ? '🥈 备选' : '🥉 备选');
          return '<div class="recommend-card" data-dish-id="' + item.id + '" data-dish-name="' + escapeHtml(item.name) + '" onclick="quickOrder(this.dataset.dishId,this.dataset.dishName)">'
            + '<div class="recommend-badge">' + badge + '</div>'
            + '<div class="recommend-name">' + escapeHtml(item.name) + '</div>'
            + '<div class="recommend-reason">' + escapeHtml(item.reason) + '</div>'
            + '</div>';
        }).join('');
      })
      .catch(function() {
        document.getElementById('recommend-grid').innerHTML = '<div class="recommend-empty">加载失败，请刷新重试</div>';
      });
  }

  function quickOrder(dishId, dishName) {
    dishId = String(dishId);
    // 使用现有点餐逻辑（与 want-btn 点击一致）
    if (window.selected && window.updateRemarkPanel) {
      if (window.selected[dishId]) {
        delete window.selected[dishId];
      } else {
        window.selected[dishId] = { id: dishId, name: dishName, remark: '' };
      }
      window.updateRemarkPanel();
      document.getElementById('count').textContent = Object.keys(window.selected).length;
      // 同步按钮状态
      var wb = document.querySelector('.want-btn[data-id="' + dishId + '"]');
      if (wb) {
        if (window.selected[dishId]) { wb.textContent = '取消'; wb.classList.add('on'); }
        else { wb.textContent = '想吃'; wb.classList.remove('on'); }
      }
    } else {
      // 回退：直接点菜
      var wb = document.querySelector('.want-btn[data-id="' + dishId + '"]');
      if (wb) wb.click();
    }
  }

  // 一键生成菜单
  var _generatedMenu = null;
  function generateMenu() {
    var btn = document.getElementById('generate-btn');
    btn.disabled = true;
    btn.querySelector('.generate-btn-text').textContent = '正在生成...';
    fetch('/api/menu/generate', { method: 'POST' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        btn.disabled = false;
        btn.querySelector('.generate-btn-text').textContent = '🎲 一键生成今日菜单';
        if (!d.success) { alert(d.message); return; }
        _generatedMenu = d.menu;
        var resultDiv = document.getElementById('menu-result');
        resultDiv.style.display = '';

        // 菜品展示
        var dishesHtml = d.menu.map(function(dish, i) {
          var role = i === 0 ? '🥩 主菜' : '🥬 配菜';
          var stars = dish.avgRating > 0 ? ' ⭐' + dish.avgRating.toFixed(1) : '';
          return '<div class="menu-dish-item">'
            + '<span class="menu-dish-role">' + role + '</span>'
            + '<span class="menu-dish-name">' + escapeHtml(dish.name) + '</span>'
            + '<span class="menu-dish-stars">' + stars + '</span>'
            + '</div>';
        }).join('');
        document.getElementById('menu-dishes').innerHTML = dishesHtml;

        // 采购清单
        var shopHtml = '';
        if (d.shoppingList && d.shoppingList.length > 0) {
          shopHtml = '<div class="menu-shopping-title">📋 采购清单</div>'
            + '<div class="menu-shopping-list">'
            + d.shoppingList.map(function(it, i) { return '<span class="menu-shop-item">' + (i+1) + '. ' + escapeHtml(it) + '</span>'; }).join('')
            + '</div>';
        }
        document.getElementById('menu-shopping').innerHTML = shopHtml;

        resultDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
      })
      .catch(function() {
        btn.disabled = false;
        btn.querySelector('.generate-btn-text').textContent = '🎲 一键生成今日菜单';
        alert('生成失败，请重试');
      });
  }

  function confirmMenu() {
    if (!_generatedMenu || _generatedMenu.length === 0) return;
    var items = _generatedMenu.map(function(d) { return { dishId: d.id, remark: '' }; });
    fetch('/api/order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items })
    })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.success) {
          document.getElementById('menu-result').style.display = 'none';
          _generatedMenu = null;
          // 使用现有庆祝逻辑
          if (d.shoppingList && d.shoppingList.length > 0) {
            showShoppingListPopup(d.shoppingList);
          }
          showCelebrate();
        } else {
          alert(d.message || '下单失败');
        }
      }).catch(function() { alert('网络错误，请稍后重试'); });
  }

  function showShoppingListPopup(list) {
    var overlay = document.createElement('div');
    overlay.className = 'shop-overlay';
    var card = document.createElement('div');
    card.className = 'shop-card';
    card.innerHTML = '<h2 class="shop-title">📋 今日采购清单</h2>'
      + '<div class="shop-list">'
      + list.map(function(it, i) { return '<span class="shop-item">' + (i+1) + '. ' + it + '</span>'; }).join('')
      + '</div>'
      + '<button class="shop-close-btn">知道了，去买菜 🛒</button>';
    overlay.appendChild(card);
    document.body.appendChild(overlay);
    card.querySelector('.shop-close-btn').addEventListener('click', function() { overlay.remove(); });
    overlay.addEventListener('click', function(e) { if (e.target === overlay) overlay.remove(); });
  }

  function showCelebrate() {
    var PHRASES = ['今晚菜单已安排 ✨', '老公收到！准备大展身手 🔥', '坐等投喂吧～😋', '今天也是被爱的一天 💕'];
    var HEART_COLORS = ['#ff6b8a','#FF7F50','#ff4d6d','#ffb3ba','#ff8a80','#f48fb1'];
    var overlay = document.createElement('div');
    overlay.className = 'celebrate-overlay';
    document.body.appendChild(overlay);
    var text = document.createElement('div');
    text.className = 'celebrate-text';
    text.textContent = PHRASES[Math.floor(Math.random() * PHRASES.length)];
    overlay.appendChild(text);
    var vw = window.innerWidth, vh = window.innerHeight;
    for (var i = 0; i < 7; i++) {
      var heart = document.createElement('div');
      heart.className = 'floating-heart';
      heart.textContent = '❤️';
      heart.style.left = (vw * 0.15 + Math.random() * vw * 0.7) + 'px';
      heart.style.bottom = '0px';
      heart.style.fontSize = (20 + Math.random() * 30) + 'px';
      heart.style.color = HEART_COLORS[Math.floor(Math.random() * HEART_COLORS.length)];
      heart.style.animationDuration = (2000 + Math.random() * 1000) + 'ms';
      heart.style.setProperty('--wiggle', ((Math.random() - 0.5) * 60) + 'px');
      heart.style.setProperty('--rise', (-(vh * 0.7 + Math.random() * vh * 0.3)) + 'px');
      overlay.appendChild(heart);
    }
    setTimeout(function() {
      overlay.remove();
      if (window.selected) {
        window.selected = {};
        if (window.updateRemarkPanel) window.updateRemarkPanel();
        var wbs = document.querySelectorAll('.want-btn');
        wbs.forEach(function(b) { b.textContent = '想吃'; b.classList.remove('on'); });
        document.getElementById('count').textContent = '0';
      }
    }, 2600);
  }

  function checkKitchenStatus() {
    var statusText = document.getElementById('status-text');
    // 淡出
    statusText.style.opacity = '0';
    statusText.style.transition = 'opacity 0.15s ease';

    fetch('/api/family/cooking-status')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        setTimeout(function() {
          if (d.cooking) {
            statusText.textContent = '大厨正在做：' + d.dishName + ' | 🔥 马上开饭';
          } else {
            statusText.textContent = '厨房暂时空闲，快去点菜吧~';
          }
          // 淡入
          statusText.style.opacity = '1';
        }, 150);
      })
      .catch(function() {
        setTimeout(function() {
          statusText.textContent = '厨房暂时空闲';
          statusText.style.opacity = '1';
        }, 150);
      });
  }

  // Socket.IO 实时推送（优先级高于轮询）
  var _socketConnected = false;
  try {
    var socket = io();
    socket.on('connect', function() {
      _socketConnected = true;
      // 加入家庭组房间
      var fgId = '<%= locals.familyGroupId || "" %>';
      if (fgId) socket.emit('join', fgId);
    });
    socket.on('order_update', function() {
      // 订单状态变更 → 刷新状态条
      checkKitchenStatus();
      // 如果当前在历史页或大厨面板，刷新列表
      if (typeof chefLoadOrders === 'function' && document.getElementById('panel-orders') && document.getElementById('panel-orders').style.display !== 'none') {
        chefLoadOrders((typeof _chefOrderPage !== 'undefined') ? _chefOrderPage : 1);
      }
      if (typeof loadHistory === 'function' && document.getElementById('history-list')) {
        loadHistory((typeof _currentPage !== 'undefined') ? _currentPage : 1);
      }
    });
    socket.on('new_order', function() {
      checkKitchenStatus();
      if (typeof chefLoadOrders === 'function') chefLoadOrders(1);
    });
    socket.on('disconnect', function() { _socketConnected = false; });
  } catch(e) { /* Socket.IO 不可用时静默降级 */ }

  // 每15秒轮询厨房状态（Socket.IO 降级方案）
  var _kitchenStatusTimer = setInterval(function() {
    if (!_socketConnected) checkKitchenStatus();
  }, 15000);
  window.addEventListener('beforeunload', function() { clearInterval(_kitchenStatusTimer); });

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }
  </script>
</body>
</html>
