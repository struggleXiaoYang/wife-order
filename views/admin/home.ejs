<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理后台</title>
  <link rel="stylesheet" href="/admin.css?v=2">
  <script src="https://cdn.jsdelivr.net/npm/qrcode@1/build/qrcode.min.js"></script>
</head>
<body data-app="admin">
  <%- include('../partials/navbar') %>

  <div class="admin-tabs">
    <button class="admin-tab active" data-view="orders">订单管理</button>
    <button class="admin-tab" data-view="dishes">菜品管理</button>
    <button class="admin-tab" data-view="categories">分类管理</button>
    <button class="admin-tab" data-view="family">家庭管理</button>
    <button class="admin-tab" data-view="inventory">库存管理</button>
    <button class="admin-tab" data-view="stats">数据统计</button>
  </div>

  <!-- 订单视图 -->
  <div class="admin-view" id="view-orders">
    <div id="order-list"></div>
  </div>

  <!-- 菜品视图 -->
  <div class="admin-view" id="view-dishes" style="display:none">
    <div class="dish-toolbar">
      <button class="add-dish-btn" id="add-dish-btn">＋ 添加菜品</button>
    </div>
    <div id="dish-list"></div>
  </div>

  <!-- 分类视图 -->
  <div class="admin-view" id="view-categories" style="display:none">
    <div class="cat-toolbar">
      <input class="cat-input" id="cat-input" placeholder="输入新分类名">
      <button class="cat-add-btn" id="cat-add-btn">添加</button>
    </div>
    <div id="cat-list"></div>
  </div>

  <!-- 库存管理视图 -->
  <div class="admin-view" id="view-inventory" style="display:none">
    <div class="inv-toolbar">
      <input class="inv-input-name" id="inv-name" placeholder="食材名（如五花肉）">
      <input class="inv-input-qty" id="inv-qty" type="number" placeholder="数量" min="0" step="0.1" value="0">
      <input class="inv-input-unit" id="inv-unit" placeholder="单位" value="份">
      <button class="inv-add-btn" id="inv-add-btn">＋ 添加</button>
    </div>
    <div id="inv-list"></div>
  </div>

  <!-- 数据统计视图 -->
  <div class="admin-view" id="view-stats" style="display:none">
    <div class="stats-grid" id="stats-grid">
      <div class="stat-card">
        <div class="stat-label">本月订单数</div>
        <div class="stat-value" id="stat-order-count">-</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">菜品总数</div>
        <div class="stat-value" id="stat-dish-count">-</div>
      </div>
      <div class="stat-card stat-card-wide">
        <div class="stat-label">⭐ 最高评分</div>
        <div class="stat-value" id="stat-top-rated" style="font-size:18px">-</div>
      </div>
    </div>
    <div class="stat-section">
      <h3 class="stat-section-title">🔥 本月热门菜品 Top 5</h3>
      <div id="stat-top-dishes"></div>
    </div>
  </div>

  <!-- 家庭管理视图 -->
  <div class="admin-view" id="view-family" style="display:none">
    <div class="family-card">
      <h3 class="family-title">邀请成员加入家庭</h3>
      <p class="family-desc">老婆扫描二维码即可自动加入你的家庭组</p>
      <button class="family-qr-btn" id="gen-qr-btn">生成邀请二维码</button>
      <div class="family-qr-wrap" id="qr-wrap" style="display:none">
        <canvas id="qr-canvas"></canvas>
        <p class="family-invite-code">邀请码：<strong id="invite-code-text"></strong></p>
        <p class="family-qr-hint">用手机扫描二维码，或直接访问下方链接注册</p>
      </div>
    </div>
  </div>

  <!-- 模态弹窗 -->
  <div class="modal-overlay" id="modal-overlay" style="display:none">
    <div class="modal-box">
      <h2 class="modal-title" id="modal-title">添加菜品</h2>
      <form id="dish-form">
        <input type="hidden" id="dish-id">
        <label class="form-label">菜名</label>
        <input class="form-input" type="text" id="dish-name" required>

        <label class="form-label">分类</label>
        <select class="form-input" id="dish-category" required></select>

        <label class="form-label">图片上传</label>
        <input class="form-input" type="file" id="dish-image-file" accept=".jpg,.jpeg,.png,.gif">
        <label class="form-label" style="margin-top:8px">图片URL</label>
        <input class="form-input" type="text" id="dish-image" placeholder="或输入图片URL（文件上传优先）">

        <label class="form-label">食材（用 、或逗号分隔）</label>
        <textarea class="form-textarea" id="dish-ingredients" rows="2"></textarea>

        <label class="form-label">步骤（每行一步）</label>
        <textarea class="form-textarea" id="dish-steps" rows="4"></textarea>

        <label class="form-check-label">
          <input type="checkbox" id="dish-available" checked> 上架（客户端可见）
        </label>

        <div class="form-actions">
          <button type="button" class="form-cancel-btn" id="modal-cancel">取消</button>
          <button type="submit" class="form-save-btn">保存</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    var STATUS_MAP = { pending: '待接单', accepted: '已接单', cooking: '烹饪中', completed: '已完成', rejected: '已拒单' };

    function formatTime(iso) {
      var d = new Date(iso);
      var pad = function(n) { return n < 10 ? '0' + n : n; };
      return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate())
        + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    }

    // === 订单列表 ===
    function loadOrders() {
      fetch('/api/admin/orders')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          var el = document.getElementById('order-list');

          if (!data.orders || data.orders.length === 0) {
            el.innerHTML = '<div class="empty-msg">还没有点餐记录</div>';
            return;
          }

          el.innerHTML = '';
          data.orders.forEach(function(order) {
            var card = document.createElement('div');
            card.className = 'order-card';

            var head = document.createElement('div');
            head.className = 'order-head';
            head.innerHTML = '<span class="order-time">' + formatTime(order.createdAt) + '</span>'
              + '<span class="order-status st-' + order.status + '">' + (STATUS_MAP[order.status] || order.status) + '</span>';

            var body = document.createElement('div');
            body.className = 'order-dishes';
            var dishParts = [];
            var dishNames = order.dishNames || [];
            var remarks = order.remarks || [];
            for (var j = 0; j < dishNames.length; j++) {
              var part = dishNames[j];
              if (remarks[j]) part += ' <span class=\"order-remark\">(' + remarks[j] + ')</span>';
              dishParts.push(part);
            }
            body.innerHTML = dishParts.join('、');

            card.appendChild(head);
            card.appendChild(body);

            // 拒单原因
            if (order.status === 'rejected' && order.rejectReason) {
              var reason = document.createElement('div');
              reason.className = 'order-reject-reason';
              reason.textContent = '原因：' + order.rejectReason;
              card.appendChild(reason);
            }

            // 按钮区
            var btns = document.createElement('div');
            btns.className = 'order-btns';

            if (order.status === 'pending') {
              var acceptBtn = document.createElement('button');
              acceptBtn.className = 'obtn-accept';
              acceptBtn.textContent = '接单';
              acceptBtn.addEventListener('click', function() {
                fetch('/api/admin/orders/' + order.id + '/accept', { method: 'PUT' })
                  .then(function(res) { return res.json(); })
                  .then(function(r) { if (r.success) loadOrders(); });
              });

              var rejectBtn = document.createElement('button');
              rejectBtn.className = 'obtn-reject';
              rejectBtn.textContent = '拒单';
              rejectBtn.addEventListener('click', function() {
                var reason = prompt('请输入拒单原因：');
                if (reason === null) return;
                fetch('/api/admin/orders/' + order.id + '/reject', {
                  method: 'PUT',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ reason: reason.trim() }),
                })
                  .then(function(res) { return res.json(); })
                  .then(function(r) { if (r.success) loadOrders(); });
              });

              btns.appendChild(acceptBtn);
              btns.appendChild(rejectBtn);
            } else if (order.status === 'accepted') {
              var cookBtn = document.createElement('button');
              cookBtn.className = 'obtn-cook';
              cookBtn.textContent = '开始烹饪';
              cookBtn.addEventListener('click', function() {
                fetch('/api/admin/orders/' + order.id + '/cook', { method: 'PUT' })
                  .then(function(res) { return res.json(); })
                  .then(function(r) { if (r.success) loadOrders(); });
              });
              btns.appendChild(cookBtn);
            } else if (order.status === 'cooking') {
              var doneBtn = document.createElement('button');
              doneBtn.className = 'obtn-done';
              doneBtn.textContent = '完成';
              doneBtn.addEventListener('click', function() {
                fetch('/api/admin/orders/' + order.id + '/complete', { method: 'PUT' })
                  .then(function(res) { return res.json(); })
                  .then(function(r) { if (r.success) loadOrders(); });
              });
              btns.appendChild(doneBtn);
            }

            card.appendChild(btns);
            el.appendChild(card);
          });
        });
    }

    // === 菜品列表 ===
    function loadDishes() {
      fetch('/api/admin/dishes')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          var el = document.getElementById('dish-list');

          if (!data.dishes || data.dishes.length === 0) {
            el.innerHTML = '<div class="empty-msg">还没有菜品</div>';
            return;
          }

          el.innerHTML = '';
          data.dishes.forEach(function(dish) {
            var card = document.createElement('div');
            card.className = 'dish-row';

            var info = document.createElement('div');
            info.className = 'dish-row-info';
            info.innerHTML = '<span class="dish-row-name">' + dish.name + '</span>'
              + '<span class="dish-row-cat">' + dish.category + '</span>'
              + '<span class="dish-row-status ' + (dish.isAvailable ? 'avail-yes' : 'avail-no') + '">'
              + (dish.isAvailable ? '上架' : '已下架') + '</span>';

            var actions = document.createElement('div');
            actions.className = 'dish-row-actions';

            var editBtn = document.createElement('button');
            editBtn.className = 'dish-edit-btn';
            editBtn.textContent = '编辑';
            editBtn.addEventListener('click', function() { openModal(dish); });

            var delBtn = document.createElement('button');
            delBtn.className = 'dish-del-btn';
            delBtn.textContent = '删除';
            delBtn.addEventListener('click', function() {
              if (!confirm('确定删除「' + dish.name + '」吗？')) return;
              fetch('/api/admin/dishes/' + dish.id, { method: 'DELETE' })
                .then(function(res) { return res.json(); })
                .then(function(result) {
                  if (result.success) loadDishes();
                });
            });

            actions.appendChild(editBtn);
            actions.appendChild(delBtn);

            card.appendChild(info);
            card.appendChild(actions);
            el.appendChild(card);
          });
        });
    }

    // === 分类列表 ===
    function loadCategories() {
      fetch('/api/admin/categories')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          var el = document.getElementById('cat-list');
          var cats = data.categories || [];

          if (cats.length === 0) {
            el.innerHTML = '<div class="empty-msg">还没有分类</div>';
            return;
          }

          el.innerHTML = '';
          cats.forEach(function(cat) {
            var row = document.createElement('div');
            row.className = 'cat-row';

            var nameSpan = document.createElement('span');
            nameSpan.className = 'cat-name';
            nameSpan.textContent = cat;

            var actions = document.createElement('div');
            actions.className = 'cat-actions';

            var renameBtn = document.createElement('button');
            renameBtn.className = 'cat-rename-btn';
            renameBtn.textContent = '重命名';
            renameBtn.addEventListener('click', function() {
              var newName = prompt('重命名「' + cat + '」为：', cat);
              if (!newName || newName.trim() === cat) return;
              fetch('/api/admin/categories/' + encodeURIComponent(cat), {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ newName: newName.trim() }),
              })
                .then(function(res) { return res.json(); })
                .then(function(result) {
                  if (result.error) { alert(result.error); return; }
                  if (result.success) loadCategories();
                });
            });

            var delBtn = document.createElement('button');
            delBtn.className = 'cat-del-btn';
            delBtn.textContent = '删除';
            delBtn.addEventListener('click', function() {
              if (!confirm('确定删除分类「' + cat + '」吗？')) return;
              fetch('/api/admin/categories/' + encodeURIComponent(cat), { method: 'DELETE' })
                .then(function(res) { return res.json(); })
                .then(function(result) {
                  if (result.error) { alert(result.error); return; }
                  if (result.success) loadCategories();
                });
            });

            actions.appendChild(renameBtn);
            actions.appendChild(delBtn);
            row.appendChild(nameSpan);
            row.appendChild(actions);
            el.appendChild(row);
          });
        });
    }

    // === 分类添加 ===
    document.getElementById('cat-add-btn').addEventListener('click', function() {
      var input = document.getElementById('cat-input');
      var name = input.value.trim();
      if (!name) return;
      fetch('/api/admin/categories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name }),
      })
        .then(function(res) { return res.json(); })
        .then(function(result) {
          if (result.error) { alert(result.error); return; }
          if (result.success) {
            input.value = '';
            loadCategories();
          }
        });
    });

    // === 弹窗逻辑 ===
    var editingId = null;

    function openModal(dish) {
      editingId = dish ? dish.id : null;
      document.getElementById('dish-id').value = dish ? dish.id : '';
      document.getElementById('dish-name').value = dish ? dish.name : '';
      document.getElementById('dish-image').value = dish && dish.image && dish.image.indexOf('http') === 0 ? dish.image : '';
      document.getElementById('dish-image-file').value = '';
      document.getElementById('dish-ingredients').value = dish ? (dish.ingredients || []).join('、') : '';
      document.getElementById('dish-steps').value = dish ? (dish.steps || []).join('\n') : '';
      document.getElementById('dish-available').checked = dish ? dish.isAvailable : true;
      document.getElementById('modal-title').textContent = dish ? '编辑菜品' : '添加菜品';

      fetch('/api/admin/categories')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          var sel = document.getElementById('dish-category');
          sel.innerHTML = '';
          data.categories.forEach(function(c) {
            var opt = document.createElement('option');
            opt.value = c;
            opt.textContent = c;
            sel.appendChild(opt);
          });
          if (dish) sel.value = dish.category;
        });

      document.getElementById('modal-overlay').style.display = 'flex';
    }

    function closeModal() {
      document.getElementById('modal-overlay').style.display = 'none';
    }

    document.getElementById('add-dish-btn').addEventListener('click', function() { openModal(null); });
    document.getElementById('modal-cancel').addEventListener('click', closeModal);
    document.getElementById('modal-overlay').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });

    document.getElementById('dish-form').addEventListener('submit', function(e) {
      e.preventDefault();

      var formData = new FormData();
      formData.append('name', document.getElementById('dish-name').value.trim());
      formData.append('category', document.getElementById('dish-category').value);
      formData.append('ingredients', document.getElementById('dish-ingredients').value.trim());
      formData.append('steps', document.getElementById('dish-steps').value.trim());
      formData.append('isAvailable', document.getElementById('dish-available').checked ? 'true' : 'false');
      formData.append('imageUrl', document.getElementById('dish-image').value.trim());

      var fileInput = document.getElementById('dish-image-file');
      if (fileInput.files && fileInput.files[0]) {
        formData.append('image', fileInput.files[0]);
      }

      var url = '/api/admin/dishes';
      var method = 'POST';
      if (editingId) {
        url += '/' + editingId;
        method = 'PUT';
      }

      fetch(url, {
        method: method,
        body: formData,
      })
        .then(function(res) { return res.json(); })
        .then(function(result) {
          if (result.success) {
            closeModal();
            loadDishes();
          }
        });
    });

    // === Tab 切换 ===
    document.querySelectorAll('.admin-tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        document.querySelectorAll('.admin-tab').forEach(function(t) { t.classList.remove('active'); });
        this.classList.add('active');

        var view = this.dataset.view;
        document.querySelectorAll('.admin-view').forEach(function(v) { v.style.display = 'none'; });
        document.getElementById('view-' + view).style.display = '';

        if (view === 'orders') loadOrders();
        else if (view === 'dishes') loadDishes();
        else if (view === 'categories') loadCategories();
        else if (view === 'family') loadFamily();
        else if (view === 'inventory') loadInventory();
        else if (view === 'stats') loadStats();
      });
    });

    // === 数据统计 ===
    function loadStats() {
      fetch('/api/admin/stats')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          document.getElementById('stat-order-count').textContent = data.orderCount || 0;
          document.getElementById('stat-dish-count').textContent = data.dishCount || 0;
          document.getElementById('stat-top-rated').textContent = data.topRated || '暂无';

          var el = document.getElementById('stat-top-dishes');
          var list = data.topDishes || [];
          if (list.length === 0) {
            el.innerHTML = '<div class=\"empty-msg\">本月还没有点餐记录</div>';
          } else {
            el.innerHTML = '';
            list.forEach(function(item, idx) {
              var row = document.createElement('div');
              row.className = 'stat-dish-row';
              var rankClass = idx === 0 ? 'stat-rank-gold' : idx === 1 ? 'stat-rank-silver' : idx === 2 ? 'stat-rank-bronze' : '';
              row.innerHTML =
                '<span class=\"stat-rank ' + rankClass + '\">' + (idx + 1) + '</span>' +
                '<span class=\"stat-dish-name\">' + item.name + '</span>' +
                '<span class=\"stat-dish-count\">' + item.count + ' 次</span>';
              el.appendChild(row);
            });
          }
        });
    }

    // === 库存管理 ===
    function loadInventory() {
      fetch('/api/inventory')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          var el = document.getElementById('inv-list');
          var items = data.items || [];
          if (items.length === 0) {
            el.innerHTML = '<div class=\"empty-msg\">还没有库存记录，请添加食材</div>';
          } else {
            el.innerHTML = '';
            items.forEach(function(item) {
              var row = document.createElement('div');
              row.className = 'inv-row';
              row.innerHTML =
                '<span class=\"inv-name\">' + item.ingredient_name + '</span>' +
                '<input class=\"inv-qty-edit\" type=\"number\" value=\"' + item.quantity + '\" min=\"0\" step=\"0.1\" data-id=\"' + item.id + '\">' +
                '<input class=\"inv-unit-edit\" value=\"' + item.unit + '\" data-id=\"' + item.id + '\">' +
                '<button class=\"inv-save-btn\" data-id=\"' + item.id + '\">保存</button>' +
                '<button class=\"inv-del-btn\" data-id=\"' + item.id + '\">删除</button>';
              el.appendChild(row);
            });
            // 绑定保存
            el.querySelectorAll('.inv-save-btn').forEach(function(btn) {
              btn.addEventListener('click', function() {
                var id = this.dataset.id;
                var qty = el.querySelector('.inv-qty-edit[data-id=\"' + id + '\"]').value;
                var unit = el.querySelector('.inv-unit-edit[data-id=\"' + id + '\"]').value;
                fetch('/api/inventory/' + id, {
                  method: 'PUT',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ quantity: qty, unit: unit }),
                }).then(function(r) { return r.json(); })
                  .then(function(r) { if (r.success) loadInventory(); });
              });
            });
            // 绑定删除
            el.querySelectorAll('.inv-del-btn').forEach(function(btn) {
              btn.addEventListener('click', function() {
                if (!confirm('确定删除？')) return;
                var id = this.dataset.id;
                fetch('/api/inventory/' + id, { method: 'DELETE' })
                  .then(function(r) { return r.json(); })
                  .then(function(r) { if (r.success) loadInventory(); });
              });
            });
          }
        });
    }

    document.getElementById('inv-add-btn').addEventListener('click', function() {
      var name = document.getElementById('inv-name').value.trim();
      if (!name) return alert('请输入食材名');
      var qty = document.getElementById('inv-qty').value;
      var unit = document.getElementById('inv-unit').value.trim() || '份';
      fetch('/api/inventory', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ingredient_name: name, quantity: qty, unit: unit }),
      }).then(function(r) { return r.json(); })
        .then(function(r) {
          if (r.success) {
            document.getElementById('inv-name').value = '';
            document.getElementById('inv-qty').value = '0';
            loadInventory();
          }
        });
    });

    // === 家庭管理 ===
    var qrGenerated = false;

    function loadFamily() {
      document.getElementById('gen-qr-btn').addEventListener('click', function() {
        if (qrGenerated) return;
        qrGenerated = true;
        var btn = this;
        btn.textContent = '生成中…';
        btn.disabled = true;

        var inviteCode = '<%= user.phone %>';
        var url = window.location.origin + '/register?invite=' + inviteCode;

        var canvas = document.getElementById('qr-canvas');
        QRCode.toCanvas(canvas, url, { width: 220, margin: 1, color: { dark: '#FF7F50', light: '#ffffff' } }, function(err) {
          if (err) {
            btn.textContent = '生成失败，点此重试';
            btn.disabled = false;
            qrGenerated = false;
            return;
          }
          document.getElementById('qr-wrap').style.display = '';
          document.getElementById('invite-code-text').textContent = inviteCode;
          btn.textContent = '已生成';
        });
      });
    }

    // 默认加载订单
    loadOrders();
  </script>
</body>
</html>
