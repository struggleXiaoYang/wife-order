<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>忘记密码 - 家庭私厨</title>
  <link rel="stylesheet" href="/style.css?v=2">
</head>
<body class="auth-body">
  <div class="auth-wrap">
    <div class="auth-card">
      <h1 class="auth-title">忘记密码</h1>
      <p class="auth-subtitle" id="step-subtitle">请输入注册时使用的手机号</p>

      <!-- 步骤1：手机号 -->
      <form class="auth-form" id="step1-form">
        <div class="auth-field">
          <label class="auth-label" for="phone">手机号</label>
          <div class="auth-row">
            <input
              class="auth-input auth-input-flex"
              type="tel"
              id="phone"
              placeholder="请输入手机号"
              maxlength="11"
              autocomplete="tel"
              required
              autofocus
            >
            <button class="auth-code-btn" type="button" id="send-code-btn">获取验证码</button>
          </div>
          <span class="auth-error" id="phone-error"></span>
        </div>
      </form>

      <!-- 步骤2：验证码 + 新密码 -->
      <form class="auth-form" id="step2-form" style="display:none">
        <div class="auth-field">
          <label class="auth-label" for="code">验证码</label>
          <input
            class="auth-input"
            type="text"
            id="code"
            placeholder="请输入验证码"
            maxlength="6"
            autocomplete="one-time-code"
            required
          >
          <span class="auth-error" id="code-error"></span>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="new-password">新密码</label>
          <input
            class="auth-input"
            type="password"
            id="new-password"
            placeholder="至少6位新密码"
            autocomplete="new-password"
            required
          >
          <span class="auth-error" id="password-error"></span>
        </div>

        <div class="auth-field">
          <label class="auth-label" for="confirm-password">确认新密码</label>
          <input
            class="auth-input"
            type="password"
            id="confirm-password"
            placeholder="请再次输入新密码"
            autocomplete="new-password"
            required
          >
          <span class="auth-error" id="confirm-error"></span>
        </div>

        <div class="auth-error-msg" id="form-error" style="display:none"></div>

        <button class="auth-btn-primary" type="submit">重置密码</button>
      </form>

      <div class="auth-links">
        <a class="auth-link" href="/login">想起密码了？<span class="auth-link-strong">返回登录</span></a>
      </div>
    </div>
  </div>

  <div class="toast" id="toast" style="display:none"></div>

  <script>
    function showToast(msg) {
      var t = document.getElementById('toast');
      t.textContent = msg;
      t.style.display = '';
      t.classList.remove('toast-show');
      void t.offsetWidth;
      t.classList.add('toast-show');
      setTimeout(function() { t.style.display = 'none'; }, 2000);
    }

    var countdown = 0;
    var timer = null;
    var sendBtn = document.getElementById('send-code-btn');

    // 发送验证码
    sendBtn.addEventListener('click', function() {
      var phone = document.getElementById('phone').value.trim();
      if (!phone || !/^1\d{10}$/.test(phone)) {
        document.getElementById('phone-error').textContent = '请输入正确的11位手机号';
        return;
      }
      document.getElementById('phone-error').textContent = '';
      if (countdown > 0) return;

      fetch('/api/forgot-password/send-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: phone }),
      })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.success) {
            showToast('验证码已发送');
            countdown = 60;
            sendBtn.disabled = true;
            sendBtn.textContent = countdown + 's';
            timer = setInterval(function() {
              countdown--;
              if (countdown <= 0) {
                clearInterval(timer);
                sendBtn.disabled = false;
                sendBtn.textContent = '获取验证码';
              } else {
                sendBtn.textContent = countdown + 's';
              }
            }, 1000);
            // 显示步骤2
            document.getElementById('step1-form').style.display = 'none';
            document.getElementById('step2-form').style.display = '';
            document.getElementById('step-subtitle').textContent = '请输入验证码并设置新密码';
          } else {
            document.getElementById('phone-error').textContent = d.message || '发送失败';
          }
        })
        .catch(function() {
          showToast('网络错误，请重试');
          sendBtn.disabled = false;
          sendBtn.textContent = '获取验证码';
          if (timer) { clearInterval(timer); timer = null; }
          countdown = 0;
        });
    });

    // 提交重置
    document.getElementById('step2-form').addEventListener('submit', function(e) {
      e.preventDefault();

      var phone = document.getElementById('phone').value.trim();
      var code = document.getElementById('code').value.trim();
      var password = document.getElementById('new-password').value;
      var confirmPassword = document.getElementById('confirm-password').value;

      ['code-error','password-error','confirm-error'].forEach(function(id) {
        document.getElementById(id).textContent = '';
      });
      document.getElementById('form-error').style.display = 'none';

      var valid = true;
      if (!code || code.length !== 6) {
        document.getElementById('code-error').textContent = '请输入6位验证码';
        valid = false;
      }
      if (!password || password.length < 6) {
        document.getElementById('password-error').textContent = '新密码至少6位';
        valid = false;
      }
      if (password !== confirmPassword) {
        document.getElementById('confirm-error').textContent = '两次密码不一致';
        valid = false;
      }
      if (!valid) return;

      var btn = this.querySelector('.auth-btn-primary');
      btn.disabled = true;
      btn.textContent = '重置中…';

      fetch('/api/forgot-password/reset', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: phone, code: code, password: password }),
      })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.success) {
            showToast('密码重置成功，请登录');
            setTimeout(function() { window.location.href = '/login'; }, 1200);
          } else {
            document.getElementById('form-error').style.display = '';
            document.getElementById('form-error').textContent = d.message || '重置失败';
            btn.disabled = false;
            btn.textContent = '重置密码';
          }
        })
        .catch(function() {
          showToast('网络错误，请重试');
          btn.disabled = false;
          btn.textContent = '重置密码';
        });
    });
  </script>
</body>
</html>
